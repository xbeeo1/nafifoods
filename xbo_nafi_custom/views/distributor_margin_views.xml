<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_distributor_margin_list" model="ir.ui.view">
            <field name="name">distributor.margin.list</field>
            <field name="model">distributor.margin</field>
            <field name="arch" type="xml">
                <list>
                    <field name="fixed_per"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_distributor_margin_form" model="ir.ui.view">
            <field name="name">distributor.margin.form</field>
            <field name="model">distributor.margin</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                        <group>
                            <field name="fixed_per"/>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_distributor_margin" model="ir.actions.act_window">
            <field name="name">Distributor Margin</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">distributor.margin</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Distributor Margin...!
                </p>
            </field>
        </record>

        <menuitem id="menu_action_distributor_margin"
                  name="Distributor Margin"
                  parent="sale.menu_sale_config"
                  action="action_distributor_margin"
                  sequence="22"/>

    </data>
</odoo>
