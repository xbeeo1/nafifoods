<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_booker_margin_list" model="ir.ui.view">
            <field name="name">booker.margin.list</field>
            <field name="model">booker.margin</field>
            <field name="arch" type="xml">
                <list>
                    <field name="fixed_per"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_booker_margin_form" model="ir.ui.view">
            <field name="name">booker.margin.form</field>
            <field name="model">booker.margin</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                        <group>
                            <field name="fixed_per"/>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_booker_margin" model="ir.actions.act_window">
            <field name="name">Booker Margin</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">booker.margin</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Booker Margin...!
                </p>
            </field>
        </record>

        <menuitem id="menu_action_booker_margin"
                  name="Booker Margin"
                  parent="sale.menu_sale_config"
                  action="action_booker_margin"
                  sequence="24"/>

    </data>
</odoo>
