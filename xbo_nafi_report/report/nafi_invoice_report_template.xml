<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="action_nafi_invoice_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="o">
                    <style>
                        .custom-table, .custom-table td {
                            border: 1px solid black;
                        }
                        .custom-table {
                            width: 100%;
                            border-collapse: collapse;
                        }
                    </style>
                    <h2 colspan="6" style="text-align: center;">
                        An Nafi Foods - Invoice
                    </h2>

                    <table class="custom-table" style="table-layout: fixed;">
                        <tr >
                            <td colspan="2" style="padding-left:2px;"><strong>Invoice No:</strong></td>
                            <td colspan="6">
                                <span t-field="o.name"/>
                            </td>
                            <td colspan="2" style="padding-left:2px;"><strong>Date</strong></td>
                            <td class="text-center" colspan="2">
                                <span t-field="o.invoice_date" t-options='{"format": "dd-MMM-yy"}'/>
                            </td>
                        </tr>
                        <tr >
                            <td colspan="2" style="padding-left:2px;">
                                <strong>Customer:</strong>
                            </td>
                            <td colspan="6">
                                <span t-field="o.partner_id.name"/>
                            </td>
                            <td colspan="2" style="padding-left:2px;"><strong>Payment Term</strong></td>
                            <td class="text-center" colspan="2">
                                <span t-field="o.invoice_payment_term_id.name"/>
                            </td>
                        </tr>
                        <tr >
                            <td colspan="2" style="padding-left:2px;"><strong>Address:</strong></td>
                            <t t-set="partner" t-value="o.partner_id"/>
                            <td colspan="10">
                                <t t-if="partner.street">
                                    <span t-esc="partner.street"/>
                                </t>

                                <t t-if="partner.street2">
                                    , <span t-esc="partner.street2"/>
                                </t>

                                <t t-if="partner.city">
                                    , <span t-esc="partner.city"/>
                                </t>

                                <t t-if="partner.country_id">
                                    , <span t-esc="partner.country_id.name"/>
                                </t>
                            </td>

                        </tr>
                        <tr>
                            <td colspan="8" style="padding-left:2px;"><strong>Transporter Builty No.</strong></td>
                            <td colspan="2" style="padding-left:2px;"><strong>Cell No.</strong></td>
                            <td class="text-center" colspan="2">
                                <t t-if="o.partner_id.phone">
                                    <span style="margin-left:11px;" t-esc="o.partner_id.phone"/>
                                </t>
                            </td>
                        </tr>
                    </table>
                    <br/>
                    <br/>
                    <table class="custom-table">
                        <thead>
                            <tr style="background-color: #c2d6d6;">
                                <th style="font-weight: bold;" class="text-center">No</th>
                                <th style="font-weight: bold;" class="text-center">DESCRIPTION</th>
                                <th style="font-weight: bold;" class="text-center">Qty(Ctn)</th>
                                <th style="font-weight: bold;" class="text-center">Trade Price</th>
                                <th style="font-weight: bold;" class="text-center">Dist Margin</th>
                                <th style="font-weight: bold;" class="text-center">Booker</th>
                                <th style="font-weight: bold;" class="text-center">Trade Offer</th>
                                <th style="font-weight: bold;" class="text-center">Amount(RS.)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="sr_no" t-value="0"/>
                            <t t-set="total_amount" t-value="0.0"/>
                            <t t-set="total_qty" t-value="0.0"/>
                            <t t-set="dist_obj" t-value="env['distributor.margin'].search([], limit=1)"/>
                            <t t-set="book_obj" t-value="env['booker.margin'].search([], limit=1)"/>
                            <t t-set="trade_obj" t-value="env['trade.offer'].search([], limit=1)"/>
                            <tr style="background-color: #c2d6d6;">
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td class="text-center">
                                    <t t-if="dist_obj">
                                        <t t-esc="int(dist_obj.fixed_per)"/>%
                                    </t>
                                </td>
                                <td class="text-center">
                                    <t t-if="book_obj">
                                        <t t-esc="int(book_obj.fixed_per)"/>%
                                    </t>
                                </td>
                                <td class="text-center">
                                    <t t-if="trade_obj">
                                        <t t-esc="int(trade_obj.fixed_per)"/>%
                                    </t>
                                </td>
                                <td></td>

                            </tr>
                            <t t-foreach="o.invoice_line_ids" t-as="line">
                                <tr>
                                    <td class="text-center">
                                        <t t-set="sr_no" t-value="sr_no + 1"/>
                                        <span t-esc="sr_no"/>
                                    </td>
                                    <td class="text-center">
                                        <t t-esc="line.product_id.display_name"/>
                                    </td>
                                    <td class="text-center">
                                        <t t-esc="int(line.quantity)"/>
                                        <t t-set="total_qty" t-value="total_qty + line.quantity"/>
                                    </td>
                                    <td class="text-center">
                                        <t t-esc="int(line.trade_price)"/>
                                    </td>
                                    <td class="text-center">
                                        <t t-esc="int(round(line.dist_margin))"/>
                                    </td>
                                    <td class="text-center">
                                        <t t-esc="int(round(line.booker_margin))"/>
                                    </td>
                                    <td class="text-center">
                                        <t t-esc="int(round(line.trade_Offer))"/>
                                    </td>
                                    <td class="text-center">
                                        <t t-esc="'{:,.0f}'.format(round(line.price_subtotal))"/>
                                        <t t-set="total_amount" t-value="total_amount + line.price_subtotal"/>
                                    </td>
                                </tr>
                            </t>
                            <tr style="background-color: #c2d6d6;">
                                <td></td>
                                <td class="text-center" style="font-weight: bold;">Total</td>
                                <td class="text-center" ><t t-esc="int(total_qty)"/></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td class="text-center" ><t t-esc="'{:,.0f}'.format(round(total_amount))"/></td>
                            </tr>
                        </tbody>

                    </table>

                    <div class="col-2" style="margin-left: 250px;margin-top: 35px;">
                        <img class="img-fluid" t-att-src="'/xbo_nafi_report/static/images/nafi_stemp.png'" width="200" height="70"/>
                    </div>
                    <p style="margin-top:10px;">
                        <strong>Approved By:Muhammad Bilal Azhar</strong>
                    </p>



                </t>
            </t>
        </t>

    </template>

</odoo>