<odoo>

    <record id="custom_paperformat" model="report.paperformat">
            <field name="name">Custom Paperformat</field>
            <field name="default" eval="True" />
            <field name="format">custom</field>
            <field name="page_height">297</field>
            <field name="page_width">210</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">50</field>
            <field name="margin_bottom">20</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">50</field>
            <field name="dpi">90</field>
        </record>



    <record id="action_nafi_report_saleorder" model="ir.actions.report">
        <field name="name">Custom Sale Order</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">xbo_nafi_report.action_nafi_sale_report_template</field>
        <field name="report_file">xbo_nafi_report.action_nafi_sale_report_template</field>
        <field name="print_report_name">"Sale Order"</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="paperformat_id" ref="xbo_nafi_report.custom_paperformat"/>
        <field name="binding_type">report</field>
    </record>


    <record id="action_nafi_invoice_report" model="ir.actions.report">
        <field name="name">Custom Report</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">xbo_nafi_report.action_nafi_invoice_report_template</field>
        <field name="report_file">xbo_nafi_report.action_nafi_invoice_report_template</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">(object._get_report_base_filename())</field>
         <field name="paperformat_id" ref="xbo_nafi_report.custom_paperformat"/>
         <field name="domain">[('move_type', '=', 'out_invoice')]</field>
    </record>





</odoo>