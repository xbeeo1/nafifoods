<odoo>
    <template id="report_purchaseorder_document_inherit_total_qty"
              inherit_id="purchase.report_purchaseorder_document">

        <xpath expr="//p[@t-field='o.note']" position="after">

            <div>
                <strong>Total Quantity:</strong>
                <span t-esc="sum(o.order_line.filtered(lambda l: not l.display_type).mapped('product_qty'))"/>
            </div>

        </xpath>

    </template>
</odoo>